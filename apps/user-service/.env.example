GRPC_SERVER_CONFIG_ADDRESS_STRING = "address of your grpcServerConfig.yml"

# ========================================
# POSTGRES CONFIGURATION
# ========================================
DB_HOST= host for your DB
DB_PORT= port for your DB
DB_NAME= name of your DB
DB_USER= user
DB_PASSWORD= yourpass

# Connection Pool Settings (default)
DB_MAX_CONNS=10
DB_MIN_CONNS=2

# Timeouts and Durations (в секундах или как числа), default
DB_HEALTH_CHECK_PERIOD=60      # 60 секунд = 1 минута
DB_MAX_CONN_LIFETIME=3600      # 3600 секунд = 1 час
DB_MAX_CONN_IDLE_TIME=1800     # 1800 секунд = 30 минут
DB_CONNECT_TIMEOUT=5           # 5 секунд